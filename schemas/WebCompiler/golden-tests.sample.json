{
  "schema_version": "golden_tests_v1",
  "tests": [
    {
      "id": "valid_homepage_compile",
      "stage": "full_pipeline",
      "input_refs": [
        "sample-site-definition.json",
        "template-registry.sample.json",
        "component-recipes.sample.json",
        "theme-pack.sample.json"
      ],
      "expected": {
        "outcome": "pass",
        "assertions": [
          "homepage compiles to render plan",
          "render plan includes page_header and service_card",
          "bundle contains homepage output"
        ]
      }
    },
    {
      "id": "template_page_type_mismatch_fails",
      "stage": "run_integrity_checks",
      "input_refs": [
        "sample-site-definition.invalid-template-mismatch.json",
        "system-integrity.sample.json"
      ],
      "expected": {
        "outcome": "fail",
        "error_code": "template_page_type_mismatch",
        "assertions": [
          "mismatched template page_type blocks compile"
        ]
      }
    },
    {
      "id": "missing_transform_fails",
      "stage": "run_integrity_checks",
      "input_refs": [
        "template-registry.invalid-transform.json",
        "transform-registry.sample.json"
      ],
      "expected": {
        "outcome": "fail",
        "error_code": "integrity_check_failed",
        "assertions": [
          "missing transform id reported"
        ]
      }
    },
    {
      "id": "bad_html_fragment_fails",
      "stage": "sanitise_html_fields",
      "input_refs": [
        "sample-site-definition.invalid-html.json",
        "html-policy.sample.json"
      ],
      "expected": {
        "outcome": "fail",
        "error_code": "html_sanitisation_failed",
        "assertions": [
          "script tag is rejected"
        ]
      }
    },
    {
      "id": "missing_optional_collection_passes",
      "stage": "compile_render_plan",
      "input_refs": [
        "sample-site-definition.minimal-contact.json"
      ],
      "expected": {
        "outcome": "pass",
        "assertions": [
          "optional opening hours block omitted cleanly"
        ]
      }
    },
    {
      "id": "policy_page_compiles_with_body_sections",
      "stage": "full_pipeline",
      "input_refs": [
        "sample-site-definition.policy-page.json"
      ],
      "expected": {
        "outcome": "pass",
        "assertions": [
          "render plan contains body_sections component with rendered bindings",
          "body section headings render as h2 in bundle html"
        ]
      }
    },
    {
      "id": "unused_content_field_warns",
      "stage": "full_pipeline",
      "input_refs": [
        "sample-site-authoring.unused-content-field.json"
      ],
      "expected": {
        "outcome": "pass",
        "assertions": [
          "normalise warns about unused body_sections field"
        ]
      }
    },
    {
      "id": "policy_page_rejects_script_in_body_section",
      "stage": "sanitise_html_fields",
      "input_refs": [
        "sample-site-definition.policy-page.invalid-html.json",
        "html-policy.sample.json"
      ],
      "expected": {
        "outcome": "fail",
        "error_code": "html_sanitisation_failed",
        "assertions": [
          "script tag is rejected for policy body sections"
        ]
      }
    },
    {
      "id": "all_render_plan_components_have_css",
      "stage": "full_pipeline",
      "input_refs": [
        "sample-site-definition.all-templates.json",
        "template-registry.sample.json",
        "component-recipes.sample.json",
        "theme-pack.sample.json"
      ],
      "expected": {
        "outcome": "pass",
        "assertions": [
          "every root_class from the render plan appears as a selector in the generated css",
          "no rule body contains a literal hex colour or pixel value where a token reference is available"
        ]
      }
    },
    {
      "id": "body_sections_renders_with_theme_typography",
      "stage": "full_pipeline",
      "input_refs": [
        "sample-site-definition.policy-page.json",
        "component-recipes.sample.json",
        "theme-pack.sample.json"
      ],
      "expected": {
        "outcome": "pass",
        "assertions": [
          "body sections css includes root heading content selectors",
          "body section heading rule references --sb-typography-scale-h2"
        ]
      }
    }
  ]
}
