{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/golden-tests.schema.json",
  "title": "Golden Tests Schema",
  "type": "object",
  "required": [
    "schema_version",
    "tests"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "golden_tests_v1"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "stage",
          "input_refs",
          "expected"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          },
          "input_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected": {
            "type": "object",
            "required": [
              "outcome"
            ],
            "additionalProperties": false,
            "properties": {
              "outcome": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail"
                ]
              },
              "error_code": {
                "type": "string"
              },
              "assertions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}