{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/site-authoring.schema.json",
  "title": "Site Authoring Schema",
  "type": "object",
  "required": [
    "schema_version",
    "site",
    "pages"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "site_authoring_v1"
    },
    "site": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "page_type",
          "content"
        ],
        "additionalProperties": true,
        "properties": {
          "page_type": {
            "type": "string"
          },
          "content": {
            "type": "object"
          }
        }
      }
    }
  }
}