          },
          {
            "id": "result",
            "element": "article",
            "source": "results",
            "repeatable": true,
            "priority": 2
          },
          {
            "id": "title",
            "element": "h2",
            "source": "title",
            "priority": 3
          },
          {
            "id": "link",
            "element": "a",
            "source": "url",
