{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/gloucester-householder-assessment-result.v2.2.schema.json",
  "title": "Gloucester Householder Planning Assessment Result v2.2",
  "description": "Structured result contract for MCP workflows. Makes explicit which modules were applicable, which were skipped, and whether an issue belongs to validation, planning merits, consultation, heritage or CIL. Designed to be produced before any narrative report \u2014 the narrative should be a view of this object, not the other way around. v2.2 adds a split between raw extracted facts and a typed normalised facts block, plus machine-readable legal basis and threshold status fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_reference",
    "scope",
    "data_quality",
    "validation",
    "planning_merits",
    "recommendation"
  ],
  "properties": {
    "case_reference": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "assessment_date": {
      "type": "string",
      "format": "date"
    },
    "facts_extracted": {
      "type": "object",
      "description": "Deprecated alias retained for backward compatibility. Prefer facts_extracted_raw and facts_extracted_normalised.",
      "additionalProperties": true,
      "deprecated": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "application_route",
        "modules_considered",
        "modules_applied"
      ],
      "description": "Invariant: modules_applied must be a subset of modules_considered. Any module in modules_considered but not in modules_applied must appear in modules_skipped with a reason.",
      "properties": {
        "application_route": {
          "type": "string",
          "enum": [
            "householder_planning_permission",
            "householder_planning_permission_and_listed_building_consent",
            "pre_application_householder",
            "prior_notification_larger_home_extension"
          ]
        },
        "modules_considered": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "national_validation",
              "local_validation_householder",
              "plans_validation",
              "flood_risk_validation",
              "policy_A1_design_and_amenity",
              "heritage_review",
              "consultations",
              "cil",
              "prior_notification_larger_home_extension"
            ]
          },
          "uniqueItems": true
        },
        "modules_applied": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "national_validation",
              "local_validation_householder",
              "plans_validation",
              "flood_risk_validation",
              "policy_A1_design_and_amenity",
              "heritage_review",
              "consultations",
              "cil",
              "prior_notification_larger_home_extension"
            ]
          },
          "uniqueItems": true
        },
        "modules_skipped": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "module",
              "reason"
            ],
            "properties": {
              "module": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "data_quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "issues"
      ],
      "description": "Data integrity checks run before validation or merits assessment. If status is 'conflicted' or 'insufficient', downstream modules should be cautious or skipped.",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "clean",
            "warnings",
            "conflicted",
            "insufficient"
          ]
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "issue_code",
              "severity",
              "description"
            ],
            "properties": {
              "issue_code": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "warning",
                  "blocking"
                ]
              },
              "description": {
                "type": "string"
              },
              "facts_affected": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "requirement_outcomes",
        "blocking_issues"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "valid",
            "invalid",
            "incomplete",
            "manual_review_required",
            "not_run"
          ]
        },
        "blocking_issues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Issues that would prevent validation. If non-empty, planning merits should normally not be run (or should be flagged as advisory only)."
        },
        "requirement_outcomes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "requirement_id",
              "source_module",
              "status",
              "applicability",
              "legal_basis",
              "effect_type"
            ],
            "properties": {
              "requirement_id": {
                "type": "string"
              },
              "requirement_name": {
                "type": "string"
              },
              "source_module": {
                "type": "string",
                "enum": [
                  "national_validation",
                  "local_validation_householder",
                  "plans_validation",
                  "flood_risk_validation"
                ]
              },
              "source_status": {
                "type": "string",
                "enum": [
                  "adopted",
                  "live_checklist",
                  "mixed_live_and_provisional",
                  "draft_or_provisional"
                ],
                "description": "Provenance of the validation requirement source document."
              },
              "applicability": {
                "type": "string",
                "enum": [
                  "applies",
                  "does_not_apply",
                  "uncertain_manual_review"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "met",
                  "missing",
                  "not_met",
                  "cannot_assess",
                  "not_checked"
                ]
              },
              "reason": {
                "type": "string"
              },
              "facts_used": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Facts schema field paths that were used to evaluate this requirement."
              },
              "facts_missing": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Facts schema field paths that were needed but absent."
              },
              "legal_basis": {
                "type": "string",
                "enum": [
                  "statutory",
                  "development_plan_policy",
                  "local_validation",
                  "local_practice",
                  "guidance_only"
                ],
                "description": "Machine-readable source basis for this requirement. Use this rather than inferring legal force from narrative text."
              },
              "effect_type": {
                "type": "string",
                "enum": [
                  "validation",
                  "planning_merit",
                  "advisory"
                ],
                "description": "Operational effect of the requirement in the workflow."
              }
            }
          }
        }
      }
    },
    "planning_merits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "rule_outcomes",
        "manual_review_flags"
      ],
      "description": "Planning merits assessment. Should be set to status 'not_run' if validation.blocking_issues is non-empty and the route is not pre_application_householder. For pre-application routes, merits may run in advisory mode even with incomplete validation.",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "concerns",
            "fail",
            "cannot_assess",
            "manual_review_required",
            "not_run"
          ]
        },
        "rule_outcomes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rule_id",
              "status",
              "applicability",
              "legal_basis",
              "effect_type",
              "threshold_status"
            ],
            "properties": {
              "rule_id": {
                "type": "string"
              },
              "rule_name": {
                "type": "string"
              },
              "test_id": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "must",
                  "must_not",
                  "should",
                  "should_not",
                  "may",
                  "informative_only"
                ],
                "description": "The severity level from the ruleset for this rule."
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "concern",
                  "fail",
                  "cannot_assess",
                  "not_applicable",
                  "manual_review_required"
                ]
              },
              "applicability": {
                "type": "string",
                "enum": [
                  "applies",
                  "does_not_apply",
                  "uncertain_manual_review"
                ]
              },
              "policy_source_status": {
                "type": "string",
                "enum": [
                  "adopted",
                  "local_practice",
                  "adopted_or_established_local_practice",
                  "draft_or_provisional"
                ],
                "description": "Provenance of the policy source. Use 'local_practice' for thresholds not found in adopted policy (e.g. 10m garden depth)."
              },
              "summary": {
                "type": "string"
              },
              "facts_used": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "facts_missing": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "officer_judgement_required": {
                "type": "boolean",
                "description": "True if the rule outcome depends on qualitative site-specific judgement that cannot be automated."
              },
              "suggested_conditions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "legal_basis": {
                "type": "string",
                "enum": [
                  "statutory",
                  "development_plan_policy",
                  "local_validation",
                  "local_practice",
                  "guidance_only"
                ],
                "description": "Machine-readable source basis for this rule."
              },
              "effect_type": {
                "type": "string",
                "enum": [
                  "validation",
                  "planning_merit",
                  "advisory"
                ],
                "description": "Operational effect of the rule in the workflow."
              },
              "threshold_status": {
                "type": "string",
                "enum": [
                  "confirmed",
                  "unconfirmed",
                  "case_by_case",
                  "not_applicable"
                ],
                "description": "Status of any operative numeric or heuristic threshold used by the rule. Use 'unconfirmed' where a locally-applied threshold has no adopted published source."
              }
            }
          }
        },
        "manual_review_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "consultations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "required",
            "not_required",
            "not_run"
          ]
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "consultee",
              "applicability"
            ],
            "properties": {
              "consultee": {
                "type": "string"
              },
              "applicability": {
                "type": "string",
                "enum": [
                  "applies",
                  "does_not_apply",
                  "uncertain_manual_review"
                ]
              },
              "mandatory": {
                "type": "boolean"
              },
              "trigger": {
                "type": "string",
                "description": "The condition that triggered this consultation."
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "cil": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "applicability": {
          "type": "string",
          "enum": [
            "applies",
            "exempt",
            "uncertain_manual_review",
            "not_run"
          ]
        },
        "exemption_reason": {
          "type": "string"
        },
        "chargeable_area_sqm": {
          "type": "number",
          "minimum": 0
        },
        "rate_basis": {
          "type": "string"
        },
        "estimated_liability": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_mode",
        "reason_summary"
      ],
      "properties": {
        "decision_mode": {
          "type": "string",
          "enum": [
            "invalid",
            "insufficient_information",
            "manual_officer_review",
            "likely_support",
            "balanced_judgement",
            "likely_refusal",
            "prior_approval_not_required",
            "prior_approval_granted",
            "prior_approval_refused",
            "unknown"
          ]
        },
        "reason_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Condition IDs from the conditions_library that would likely be applied."
        },
        "informatives": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Informative IDs from the informatives_library that would likely be included."
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "facts_extracted_raw": {
      "type": "object",
      "description": "Raw extracted facts and parser artefacts before canonical normalisation. Deliberately open to support messy ingestion and intermediate extraction output.",
      "additionalProperties": true
    },
    "facts_extracted_normalised": {
      "$ref": "https://example.local/schemas/gloucester-householder-application-facts.v2.2.schema.json#/$defs/extractedFactsProjection",
      "description": "Typed, normalised facts extracted from the submission. Partial by design: only facts actually extracted with sufficient confidence need be included."
    }
  }
}